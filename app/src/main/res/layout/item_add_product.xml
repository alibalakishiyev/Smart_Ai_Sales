<?xml version="1.0" encoding="utf-8"?>
<!--
    item_add_product.xml
    "Məhsul əlavə et" düyməsi — products container-ın son elementi
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="40dp"
    android:orientation="horizontal"
    android:gravity="center"
    android:layout_marginTop="4dp">

    <TextView
        android:id="@+id/tvAddProduct"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="+ Məhsul əlavə et"
        android:textColor="#3A3852"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:background="@drawable/shape_add_product_bg" />

</LinearLayout>