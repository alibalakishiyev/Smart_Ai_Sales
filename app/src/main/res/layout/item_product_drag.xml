<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:layout_marginHorizontal="4dp"
    app:cardBackgroundColor="@color/card_light"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="@color/purple_500"
    app:cardPreventCornerOverlap="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Üst hissə - Sıra nömrəsi, Məhsul adı və silmə düyməsi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Sürüşdürmə handle -->
            <ImageView
                android:id="@+id/ivDragHandle"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_drag_handle"
                android:tint="@color/purple_500"
                android:layout_marginEnd="8dp" />

            <!-- Sıra nömrəsi dairəsi -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRowNumber"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/purple_500"
                app:cardElevation="2dp"
                android:layout_marginEnd="12dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvRowNumber"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Məhsul adı - BÖYÜK və AYDIN -->
            <TextView
                android:id="@+id/tvProductNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Məhsul:"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutProductName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/purple_500"
                app:boxStrokeWidth="1.5dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:placeholderText="Məs: Süd"
                app:placeholderTextColor="@color/text_secondary"
                app:endIconMode="clear_text"
                app:endIconDrawable="@drawable/ic_clear"
                app:endIconTint="@color/purple_500"
                app:counterEnabled="true"
                app:counterMaxLength="100"
                app:counterTextColor="@color/text_secondary"
                app:counterOverflowTextColor="@color/error">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProductName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="56dp"
                    android:hint="Məhsul adı"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="normal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:maxLines="1"
                    android:lines="1"
                    android:scrollHorizontally="true"
                    android:ellipsize="none"
                    android:inputType="textCapSentences"
                    android:fontFamily="sans-serif"
                    android:background="@null"
                    android:gravity="center_vertical|start"
                    android:singleLine="true"
                    android:scrollbarSize="10dp"
                    android:scrollbarThumbVertical="@null"
                    android:scrollbarTrackVertical="@null"
                    android:fadeScrollbars="false"
                    android:scrollbarAlwaysDrawHorizontalTrack="true"
                    android:scrollbarDefaultDelayBeforeFade="0"
                    android:scrollbarFadeDuration="0" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Silmə düyməsi -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemove"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textStart"
                app:iconSize="24dp"
                app:iconPadding="0dp"
                android:backgroundTint="@color/error_alpha"
                app:cornerRadius="24dp"
                app:strokeColor="@color/error"
                app:strokeWidth="1.5dp"
                android:contentDescription="Sil"
                android:visibility="visible"
                android:elevation="2dp" />
        </LinearLayout>

        <!-- Alt hissə - Miqdar, Qiymət və Cəm -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/card_dark"
            android:padding="12dp"
            android:elevation="2dp">

            <!-- Miqdar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Miqdar"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/purple_500"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etQuantity"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="0"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="4dp"
                        android:fontFamily="sans-serif" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Qiymət -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Qiymət"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:layout_marginBottom="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/purple_500"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:prefixText="₼ "
                    app:prefixTextColor="@color/purple_500">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPrice"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="0.00"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="4dp"
                        android:fontFamily="sans-serif" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Cəm -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cəm"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:gravity="center"
                    android:textColor="@color/success"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/total_background"
                    android:padding="8dp"
                    android:text="0.00₼" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>