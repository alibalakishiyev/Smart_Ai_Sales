<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_dark"
    android:maxHeight="600dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@color/purple_500">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_chat_bot"
            android:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🤖 AI Maliyyə Köməkçisi"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <ImageView
            android:id="@+id/btnLanguage"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_language"
            android:tint="@color/white"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvLanguageName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🇦🇿 Az"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:tint="@color/white"
            android:padding="6dp" />

    </LinearLayout>

    <!-- Chat Container -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_dark"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💬 Heç bir mesaj yoxdur"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="32dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Input Area - DÜZGÜN VERSİYA (TextInputLayout olmadan) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/card_dark"
        android:elevation="4dp">

        <EditText
            android:id="@+id/etUserInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Sualınızı yazın..."
            android:background="@drawable/edittext_bg"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:inputType="textMultiLine"
            android:maxLines="3" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="➤"
            android:textSize="20sp"
            android:layout_marginStart="8dp"
            android:background="@drawable/circle_purple"
            android:textColor="@color/white" />

    </LinearLayout>

</LinearLayout>