<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Məhsul adı -->
        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Məhsul adı"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp"/>

        <!-- Local price -->
        <TextView
            android:id="@+id/tvLocalPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sizin qiymət: ₼0.00"
            android:textSize="14sp"
            android:textColor="@color/expense_red"
            android:layout_marginBottom="4dp"/>

        <!-- BazarStore price -->
        <TextView
            android:id="@+id/tvBazarPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BazarStore: ₼0.00"
            android:textSize="14sp"
            android:textColor="@color/success"
            android:layout_marginBottom="8dp"/>

        <!-- Savings -->
        <TextView
            android:id="@+id/tvSavings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Qənaət: ₼0.00"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/success"
            android:layout_marginBottom="8dp"/>

        <!-- Store info -->
        <TextView
            android:id="@+id/tvStore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏪 BazarStore - 0% endirim"
            android:textSize="12sp"
            android:textColor="@color/white_60"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/white_20"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>